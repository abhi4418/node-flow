generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflows Workflow[]
  executions WorkflowExecution[]
}

model Workflow {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  
  // Store the workflow graph as JSON
  nodes       Json
  edges       Json
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions  WorkflowExecution[]

  @@index([userId])
}

model WorkflowExecution {
  id          String   @id @default(cuid())
  workflowId  String
  userId      String
  
  // Execution mode: "full", "single", "selected"
  mode        String   @default("full")
  
  // Which node IDs were selected for execution (if mode is "single" or "selected")
  selectedNodes Json?
  
  // Execution status: "pending", "running", "completed", "failed", "cancelled"
  status      String   @default("pending")
  
  // Store node outputs and errors
  nodeOutputs Json?
  nodeErrors  Json?
  
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([userId])
  @@index([status])
}
