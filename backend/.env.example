# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Clerk Authentication
# Get your secret key from: https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# PostgreSQL Database
# Example: postgresql://user:password@localhost:5432/workflow_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workflow_db

# Trigger.dev Configuration
# Get your secret key from: https://trigger.dev
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxxx

# Google Gemini API
# Get your API key from: https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Transloadit Configuration
# Get your credentials from: https://transloadit.com/c/signup/
TRANSLOADIT_AUTH_KEY=your_transloadit_auth_key
TRANSLOADIT_AUTH_SECRET=your_transloadit_auth_secret
